      "backoff": "exponential"
    }
  },
  "memory_system": {
    "architecture": "three_tier",
    "layers": {
      "ephemeral": {
        "ttl_seconds": 3600,
        "storage": "redis",
        "purpose": "current_conversation_context",
        "max_size_mb": 100,
        "eviction": "lru"
      },
      "working": {
        "ttl_seconds": 259200,
        "storage": "postgresql",
        "purpose": "active_projects_and_tasks",
        "max_size_mb": 1024,
        "eviction": "confidence_based"
      },
      "long_term": {
        "ttl_seconds": -1,
        "storage": "qdrant",
        "purpose": "knowledge_and_experience",
        "max_size_mb": 10240,
        "eviction": "never_unless_user_requested"
      }
    },
    "objects": {
      "fact": {
        "fields": ["content", "source", "confidence", "timestamp", "tags"],
        "indexed": ["tags", "timestamp", "confidence"]
      },
      "decision": {
        "fields": ["context", "choice", "rationale", "outcome", "timestamp"],
        "indexed": ["timestamp", "outcome"]
      },
      "lesson": {
        "fields": ["mistake", "correction", "result", "timestamp"],
        "indexed": ["timestamp"]
      },
      "artifact": {
        "fields": ["path", "hash", "purpose", "dependencies", "timestamp"],
        "indexed": ["path", "hash"]
      },
      "conversation": {
        "fields": ["messages", "mode", "model", "timestamp"],
        "indexed": ["timestamp", "mode"]
      }
    },
    "sharing": {
      "read": ["all_ai_instances"],
      "write": ["authorized_agents_only"],
      "sync_interval_seconds": 60
    },
    "privacy": {
      "encrypt_at_rest": true,
      "encrypt_in_transit": true,
      "user_can_delete": true,
      "user_can_export": true
    }
  },
  "memory_pruner": {
    "enabled": true,
    "schedule_cron": "0 3 * * *",
    "rules": [
      {
        "name": "delete_low_confidence_old_data",
        "condition": "confidence < 0.3 AND age_days > 90",
        "action": "delete"
      },
      {
        "name": "merge_duplicate_facts",
        "condition": "similarity > 0.95",
        "action": "merge_keep_highest_confidence"
      },
      {
        "name": "downgrade_unused_memories",
        "condition": "access_count == 0 AND age_days > 30",
        "action": "move_to_cold_storage"
      },
      {
        "name": "preserve_user_pinned",
        "condition": "user_pinned == true",
        "action": "never_delete"
      },
      {
        "name": "preserve_high_value",
        "condition": "confidence > 0.9 OR reference_count > 5",
        "action": "protect"
      }
    ],
    "dry_run": false,
    "log_pruning_actions": true,
    "notification": "summary_daily"
  },
