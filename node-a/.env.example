# node-a/.env.example
# Project Chimera — Node A (192.168.1.9) — RX 7900 XT
#
# Usage:
#   cp node-a/.env.example node-a/.env
#   # Edit node-a/.env and fill in all CHANGE_ME placeholders
#   bash node-a/scripts/deploy.sh

###############################################################################
# SECRETS — replace every CHANGE_ME before deploying
# Generate random keys with: openssl rand -base64 32
###############################################################################

# vLLM OpenAI-compatible API key (used by LiteLLM and OpenWebUI to auth)
VLLM_API_KEY=CHANGE_ME

# LiteLLM master key (used by clients querying the LiteLLM proxy)
LITELLM_MASTER_KEY=CHANGE_ME

# Open WebUI session secret — must be a long random string
WEBUI_SECRET_KEY=CHANGE_ME

# Hugging Face token — needed to download gated models
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=CHANGE_ME

# Qdrant REST API key (leave empty string to disable auth in dev)
QDRANT_API_KEY=CHANGE_ME

###############################################################################
# TUNABLES — safe defaults for RX 7900 XT (20 GB VRAM)
###############################################################################

# Model to serve via vLLM (must fit within VLLM_GPU_MEM_UTIL * 20 GB)
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct

# Inference dtype: float16 is the recommended default for ROCm
VLLM_DTYPE=float16

# Maximum context length in tokens
VLLM_MAX_LEN=8192

# Fraction of VRAM reserved for the model (0.88 ≈ 17.6 GB)
VLLM_GPU_MEM_UTIL=0.88

# Maximum concurrent inference sequences
VLLM_MAX_NUM_SEQS=8

# Embedding model served by TEI (CPU-only)
EMBED_MODEL=BAAI/bge-base-en-v1.5
