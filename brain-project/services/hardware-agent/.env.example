# Hardware Monitoring Agent Environment Variables

# Alert Thresholds
GPU_TEMP_THRESHOLD=80
VRAM_THRESHOLD=90
CPU_THRESHOLD=90
MEMORY_THRESHOLD=90

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# Monitoring Settings
METRICS_INTERVAL=30
METRICS_RETENTION_DAYS=7
DATA_DIR=/app/data/metrics

# ROCm Configuration
ROCM_SMI_PATH=/opt/rocm/bin/rocm-smi
ROCM_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/hardware-agent.log
