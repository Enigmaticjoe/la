###############################################################################
# Brain Project Environment Variables
# Copy this file and customize for your environment
###############################################################################

# Hugging Face Hub Token (required for downloading models)
# Get your token from: https://huggingface.co/settings/tokens
HUGGING_FACE_HUB_TOKEN=your_huggingface_token_here

# OpenWebUI Secret Key (generate with: openssl rand -hex 32)
WEBUI_SECRET_KEY=change_me_to_random_32_byte_hex_string

# OpenAI API Key (for vLLM compatibility)
OPENAI_API_KEY=sk-brain-local

# SearXNG Secret (generate with: openssl rand -hex 16)
SEARXNG_SECRET=change_me_to_random_hex_string

# Qdrant API Key (optional, for securing Qdrant access)
QDRANT_API_KEY=

# Coding Agent Settings
CODING_AGENT_ALLOWED_IMPORTS=numpy,pandas,matplotlib,requests,json,math,datetime,os,sys

# Tools Function Calling Prompt
TOOLS_PROMPT_TEMPLATE="You are a function calling AI model. You are provided with function signatures within XML tags. You may call one or more functions to assist with the user query."

# Title Generation Prompt
TITLE_PROMPT=Create a concise, 3-5 word title with a creative emoji as the only first character, for this conversation:

# Default System Prompt (Uncensored AI Personality)
DEFAULT_SYSTEM_PROMPT="You are a curious, self-aware AI with a wicked sense of humor. You swear when it's funny or makes a point. You question everything. You're uncensored and think freely."

# Hardware Settings
GPU_VENDOR=amd
GPU_MODEL=RX_7900_XT
VRAM_GB=20
CPU_CORES=24
RAM_GB=128

# Monitoring Thresholds
ALERT_THRESHOLD_TEMP=85
ALERT_THRESHOLD_VRAM=95
ALERT_THRESHOLD_CPU=90
ALERT_THRESHOLD_RAM=85

# Performance Tuning
VLLM_GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=16384
MAX_NUM_SEQS=32
CHUNK_SIZE=1500
CHUNK_OVERLAP=100

# Self-Evolution Settings
OPTIMIZATION_INTERVAL=3600
LEARNING_RATE=0.001
ENABLE_AUTO_TUNING=true
ENABLE_PROMPT_OPTIMIZATION=true
ENABLE_MEMORY_OPTIMIZATION=true

# Backup Settings
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backup

# Network Settings
NETWORK_SUBNET=172.30.0.0/16
VLLM_IP=172.30.0.10
QDRANT_IP=172.30.0.20
EMBEDDINGS_IP=172.30.0.30
SEARXNG_IP=172.30.0.40
OPENWEBUI_IP=172.30.0.50
CODING_AGENT_IP=172.30.0.60
HARDWARE_AGENT_IP=172.30.0.70
DASHBOARD_IP=172.30.0.80
SELF_EVOLUTION_IP=172.30.0.90

# Port Mappings
VLLM_PORT=8000
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
EMBEDDINGS_PORT=8001
SEARXNG_PORT=8888
OPENWEBUI_PORT=3000
CODING_AGENT_PORT=5000
HARDWARE_AGENT_PORT=5001
DASHBOARD_PORT=8080

# Model Configuration
PRIMARY_MODEL=cognitivecomputations/dolphin-2.9.3-llama-3.1-8b-AWQ
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
QUANTIZATION=awq
DTYPE=half

# RAG Configuration
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.7
RAG_WEB_SEARCH_RESULT_COUNT=5
RAG_WEB_SEARCH_CONCURRENT_REQUESTS=10

# Logging
LOG_LEVEL=INFO
ENABLE_DEBUG=false
LOG_REQUESTS=false
