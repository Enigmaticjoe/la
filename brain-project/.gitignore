# Brain Project .gitignore

# Data and caches
data/
models/
*.cache/
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment files
.env
.env.local
.env.*.backup

# Docker volumes
volumes/

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-*

# Temporary files
*.tmp
*.temp
/tmp/

# Backups
*.backup
*.bak
backup/

# Compiled files
*.so
*.dylib
*.dll

# Python
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# Node (if any frontend tools)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Secrets and keys
*.key
*.pem
*.crt
*.p12
secrets/

# Database dumps
*.sql
*.sqlite
*.db

# Large model files (use LFS or download separately)
*.bin
*.gguf
*.safetensors
*.pt
*.pth
*.onnx
!.gitkeep
