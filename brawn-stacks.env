# =============================================================================
#  BRAWN MASTER .env FILE
#  Location: /mnt/user/appdata/brawn-stacks.env
#  Used by: All Portainer stacks (load via "Load variables from .env file")
# =============================================================================

# ── TIMEZONE ─────────────────────────────────────────────────
TZ=America/New_York

# ── REAL-DEBRID ──────────────────────────────────────────────
# Get from: https://real-debrid.com/apitoken
RD_API_KEY=YOUR_REAL_DEBRID_API_KEY

# ── VPN (Mullvad WireGuard) ─────────────────────────────────
# IMPORTANT: Generate NEW keys from Mullvad dashboard!
VPN_PROVIDER=custom
VPN_ENDPOINT_IP=YOUR_MULLVAD_ENDPOINT_IP
VPN_ENDPOINT_PORT=51820
WIREGUARD_PUBLIC_KEY=YOUR_NEW_PUBLIC_KEY
WIREGUARD_PRIVATE_KEY=YOUR_NEW_PRIVATE_KEY
WIREGUARD_ADDRESSES=YOUR_WIREGUARD_ADDRESS/32

# ── PLEX ─────────────────────────────────────────────────────
# Claim token (one-time): https://plex.tv/claim
PLEX_CLAIM=
PLEX_TOKEN=YOUR_PLEX_TOKEN

# ── NEXTCLOUD ────────────────────────────────────────────────
NC_DB_ROOT_PASS=CHANGE_THIS_ROOT_PASSWORD
NC_DB_PASS=CHANGE_THIS_DB_PASSWORD
NC_REDIS_PASS=CHANGE_THIS_REDIS_PASSWORD

# ── ANYTHINGLLM ──────────────────────────────────────────────
ANYTHINGLLM_AUTH_TOKEN=GENERATE_A_RANDOM_TOKEN_HERE
ANYTHINGLLM_JWT_SECRET=GENERATE_A_RANDOM_SECRET_HERE

# ── UNRAID API ───────────────────────────────────────────────
# Generate at: Unraid → Settings → Management Access → API Keys (Viewer role)
UNRAID_API_KEY=YOUR_GRAPHQL_API_KEY

# ── MQTT ─────────────────────────────────────────────────────
MQTT_USER=mqtt_user
MQTT_PASS=CHANGE_THIS_MQTT_PASSWORD
